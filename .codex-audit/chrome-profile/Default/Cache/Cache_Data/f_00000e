const __vite__css = "\r\n\r\n@import url('https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700;900&display=swap');\n/* ============================================\r\n   불키우기 - Fire Clicker\r\n   Immersive fire-gazing UI\r\n   ============================================ */\n/* === Reset & Base === */\n*, *::before, *::after {\r\n  margin: 0; padding: 0; box-sizing: border-box;\r\n}\n:root {\r\n  --fire-orange: #ff6b1a;\r\n  --fire-red: #e83a14;\r\n  --fire-yellow: #ffcc02;\r\n  --fire-white: #fff8e7;\r\n  --ember-glow: #ff4500;\r\n  --ash-gray: #8a8a8a;\r\n  --night-dark: #0a0a0f;\r\n  --night-blue: #0d0d1a;\r\n  --drawer-bg: rgba(15, 12, 8, 0.95);\r\n  --drawer-border: rgba(255, 107, 26, 0.15);\r\n  --text-warm: #e8d5b7;\r\n  --text-dim: #7a6e5f;\r\n  --gold: #ffd700;\r\n  --rarity-common: #b0b0b0;\r\n  --rarity-uncommon: #4caf50;\r\n  --rarity-rare: #2196f3;\r\n  --rarity-epic: #9c27b0;\r\n  --rarity-legendary: #ff9800;\r\n  --rarity-mythic: #e91e63;\r\n  --safe-bottom: env(safe-area-inset-bottom, 0px);\r\n  --safe-top: env(safe-area-inset-top, 0px);\r\n}\nhtml, body {\r\n  width: 100%; height: 100%;\r\n  overflow: hidden;\r\n  background: var(--night-dark);\r\n  font-family: 'Noto Sans KR', sans-serif;\r\n  color: var(--text-warm);\r\n  user-select: none;\r\n  -webkit-user-select: none;\r\n  -webkit-tap-highlight-color: transparent;\r\n  touch-action: manipulation;\r\n}\n/* === App Container === */\n#app {\r\n  position: fixed;\r\n  inset: 0;\r\n  overflow: hidden;\r\n  background: linear-gradient(180deg, #050510 0%, #0a0a1a 40%, #1a0f08 70%, #0d0805 100%);\r\n}\n/* === Canvas Layers === */\ncanvas {\r\n  position: absolute;\r\n  top: 0; left: 0;\r\n  width: 100%; height: 100%;\r\n  pointer-events: none;\r\n}\n#fireCanvas {\r\n  z-index: 2;\r\n  mix-blend-mode: screen;\r\n  filter: blur(0px) saturate(1.45) brightness(1.12) contrast(1.03);\r\n}\n#groundCanvas {\r\n  z-index: 1;\r\n}\n#imageCanvas {\r\n  z-index: 1;\r\n  mix-blend-mode: normal;\r\n}\n#bgCanvas {\r\n  z-index: 0;\r\n}\n#toothpickCanvas {\r\n  z-index: 3;\r\n  mix-blend-mode: normal;\r\n}\n#particleCanvas {\r\n  z-index: 4;\r\n}\n/* === Fire Glow === */\n#fireGlow {\r\n  position: absolute;\r\n  bottom: 15%;\r\n  left: 50%;\r\n  transform: translateX(-50%);\r\n  width: 120vw;\r\n  height: 80vh;\r\n  background: radial-gradient(ellipse at 50% 80%,\r\n    rgba(255, 100, 20, 0.12) 0%,\r\n    rgba(255, 60, 10, 0.06) 30%,\r\n    rgba(180, 30, 0, 0.03) 50%,\r\n    transparent 70%\r\n  );\r\n  z-index: 1;\r\n  pointer-events: none;\r\n  transition: opacity 0.5s;\r\n  animation: glowShimmer 4s ease-in-out infinite;\r\n}\n@keyframes glowShimmer {\r\n  0%, 100% { transform: translateX(-50%) scaleX(1) scaleY(1); }\r\n  25% { transform: translateX(-50.3%) scaleX(1.015) scaleY(0.995); }\r\n  50% { transform: translateX(-49.7%) scaleX(0.99) scaleY(1.008); }\r\n  75% { transform: translateX(-50.1%) scaleX(1.008) scaleY(1.003); }\r\n}\n/* === Heat Shimmer (atmospheric distortion above fire) === */\n#heatShimmer {\r\n  position: absolute;\r\n  bottom: 38%;\r\n  left: 25%;\r\n  width: 50%;\r\n  height: 22%;\r\n  z-index: 3;\r\n  pointer-events: none;\r\n  opacity: 0;\r\n  transition: opacity 3s;\r\n  mask-image: linear-gradient(to top,\r\n    rgba(0,0,0,0.4) 0%,\r\n    rgba(0,0,0,0.15) 50%,\r\n    transparent 100%\r\n  );\r\n  -webkit-mask-image: linear-gradient(to top,\r\n    rgba(0,0,0,0.4) 0%,\r\n    rgba(0,0,0,0.15) 50%,\r\n    transparent 100%\r\n  );\r\n}\n#heatShimmer.active {\r\n  opacity: 1;\r\n  backdrop-filter: blur(0.3px);\r\n  -webkit-backdrop-filter: blur(0.3px);\r\n  animation: shimmerWave 3.5s ease-in-out infinite;\r\n}\n@keyframes shimmerWave {\r\n  0%, 100% {\r\n    backdrop-filter: blur(0.2px);\r\n    -webkit-backdrop-filter: blur(0.2px);\r\n    transform: translateY(0) scaleX(1);\r\n  }\r\n  30% {\r\n    backdrop-filter: blur(0.5px);\r\n    -webkit-backdrop-filter: blur(0.5px);\r\n    transform: translateY(-1px) scaleX(1.008);\r\n  }\r\n  60% {\r\n    backdrop-filter: blur(0.3px);\r\n    -webkit-backdrop-filter: blur(0.3px);\r\n    transform: translateY(-0.5px) scaleX(0.995);\r\n  }\r\n}\n/* === Fireworks Container === */\n#fireworksContainer {\r\n  position: absolute;\r\n  inset: 0;\r\n  z-index: 10;\r\n  pointer-events: none;\r\n}\n/* === Screen Shake Wrapper === */\n#shakeWrapper {\r\n  position: absolute;\r\n  inset: 0;\r\n  z-index: 4;\r\n  pointer-events: none;\r\n}\n/* === Tap Ripple === */\n#tapRipple {\r\n  display: none;\r\n  position: absolute;\r\n  width: 60px; height: 60px;\r\n  border-radius: 50%;\r\n  background: radial-gradient(circle, rgba(255,200,50,0.4) 0%, transparent 70%);\r\n  transform: translate(-50%, -50%) scale(0);\r\n  pointer-events: none;\r\n  z-index: 5;\r\n}\n#tapRipple.active {\r\n  display: block;\r\n  animation: tapRippleAnim 0.6s ease-out forwards;\r\n}\n@keyframes tapRippleAnim {\r\n  0% { transform: translate(-50%, -50%) scale(0); opacity: 1; }\r\n  100% { transform: translate(-50%, -50%) scale(3); opacity: 0; }\r\n}\n/* === HUD === */\n#hud {\r\n  position: absolute;\r\n  top: calc(12px + var(--safe-top));\r\n  left: 12px;\r\n  right: 12px;\r\n  z-index: 20;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: flex-start;\r\n  pointer-events: none;\r\n  opacity: 0.85;\r\n  transition: opacity 0.5s;\r\n}\n.ambient-mode #hud { opacity: 0; }\n#fireLevel {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 6px;\r\n  background: rgba(0,0,0,0.4);\r\n  backdrop-filter: blur(8px);\r\n  -webkit-backdrop-filter: blur(8px);\r\n  border: 1px solid rgba(255,107,26,0.2);\r\n  border-radius: 20px;\r\n  padding: 6px 14px;\r\n  pointer-events: auto;\r\n}\n#fireLevelIcon {\r\n  font-size: 18px;\r\n  filter: drop-shadow(0 0 4px var(--fire-orange));\r\n}\n#fireLevelText {\r\n  font-size: 14px;\r\n  font-weight: 700;\r\n  color: var(--fire-yellow);\r\n  text-shadow: 0 0 8px rgba(255,204,2,0.5);\r\n}\n#xpBar {\r\n  width: 60px; height: 4px;\r\n  background: rgba(255,255,255,0.1);\r\n  border-radius: 2px;\r\n  overflow: hidden;\r\n}\n#xpFill {\r\n  height: 100%;\r\n  width: 0%;\r\n  background: linear-gradient(90deg, var(--fire-orange), var(--fire-yellow));\r\n  border-radius: 2px;\r\n  transition: width 0.3s ease;\r\n  box-shadow: 0 0 6px var(--fire-orange);\r\n}\n#currencyDisplay {\r\n  display: flex;\r\n  gap: 10px;\r\n  pointer-events: auto;\r\n}\n.currency {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 4px;\r\n  background: rgba(0,0,0,0.4);\r\n  backdrop-filter: blur(8px);\r\n  -webkit-backdrop-filter: blur(8px);\r\n  border: 1px solid rgba(255,255,255,0.08);\r\n  border-radius: 16px;\r\n  padding: 5px 12px;\r\n  font-size: 13px;\r\n  font-weight: 500;\r\n}\n.currency-icon {\r\n  width: 16px; height: 16px;\r\n  border-radius: 50%;\r\n  display: inline-block;\r\n}\n.ash-icon {\r\n  background: radial-gradient(circle, #aaa 30%, #666 100%);\r\n  box-shadow: 0 0 4px rgba(150,150,150,0.5);\r\n}\n.ember-icon {\r\n  background: radial-gradient(circle, var(--fire-yellow) 20%, var(--fire-orange) 60%, var(--fire-red) 100%);\r\n  box-shadow: 0 0 6px var(--ember-glow);\r\n  animation: emberPulse 1.5s ease-in-out infinite;\r\n}\n@keyframes emberPulse {\r\n  0%, 100% { box-shadow: 0 0 4px var(--ember-glow); }\r\n  50% { box-shadow: 0 0 10px var(--ember-glow), 0 0 20px rgba(255,69,0,0.3); }\r\n}\n/* === Temperature Indicator === */\n#tempIndicator {\r\n  position: absolute;\r\n  right: 12px;\r\n  top: 50%;\r\n  transform: translateY(-50%);\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  gap: 4px;\r\n  z-index: 20;\r\n  opacity: 0.6;\r\n  transition: opacity 0.5s;\r\n  pointer-events: none;\r\n}\n.ambient-mode #tempIndicator { opacity: 0; }\n#tempBar {\r\n  width: 6px;\r\n  height: 120px;\r\n  background: rgba(255,255,255,0.08);\r\n  border-radius: 3px;\r\n  overflow: hidden;\r\n  position: relative;\r\n}\n#tempFill {\r\n  position: absolute;\r\n  bottom: 0;\r\n  width: 100%;\r\n  height: 30%;\r\n  background: linear-gradient(0deg, var(--fire-red), var(--fire-orange), var(--fire-yellow));\r\n  border-radius: 3px;\r\n  transition: height 0.5s ease;\r\n}\n#tempText {\r\n  font-size: 10px;\r\n  color: var(--text-dim);\r\n  white-space: nowrap;\r\n}\n/* === Floating Numbers — smaller, less intrusive === */\n#floatingNumbers {\r\n  position: absolute;\r\n  inset: 0;\r\n  z-index: 15;\r\n  pointer-events: none;\r\n  overflow: hidden;\r\n}\n.float-num {\r\n  position: absolute;\r\n  font-size: 14px;\r\n  font-weight: 700;\r\n  color: rgba(255, 200, 100, 0.9);\r\n  text-shadow: 0 0 6px var(--fire-orange), 0 1px 3px rgba(0,0,0,0.9);\r\n  animation: floatUp 1.1s ease-out forwards;\r\n  white-space: nowrap;\r\n}\n.float-num.big {\r\n  font-size: 20px;\r\n  color: var(--gold);\r\n  text-shadow: 0 0 12px var(--gold), 0 0 24px var(--fire-orange);\r\n}\n.float-num.mega {\r\n  font-size: 30px;\r\n  color: #fff;\r\n  text-shadow: 0 0 18px var(--fire-yellow), 0 0 36px var(--fire-orange), 0 0 54px var(--fire-red);\r\n}\n@keyframes floatUp {\r\n  0%   { transform: translateY(0) scale(0.6); opacity: 0; }\r\n  20%  { transform: translateY(-8px) scale(1.05); opacity: 0.9; }\r\n  100% { transform: translateY(-80px) scale(0.75); opacity: 0; }\r\n}\n/* === Throw Layer === */\n#throwLayer {\r\n  position: absolute;\r\n  inset: 0;\r\n  z-index: 28;\r\n  pointer-events: none;\r\n  overflow: hidden;\r\n}\n.throw-item {\r\n  position: absolute;\r\n  font-size: 28px;\r\n  animation: throwArc 0.8s cubic-bezier(0.2, 0, 0.3, 1) forwards;\r\n}\n@keyframes throwArc {\r\n  0% { transform: translate(0, 0) scale(1) rotate(0deg); opacity: 1; }\r\n  60% { transform: translate(var(--dx), var(--dy)) scale(0.8) rotate(180deg); opacity: 1; }\r\n  100% { transform: translate(var(--dx), var(--dy)) scale(0) rotate(360deg); opacity: 0; }\r\n}\n/* === Inventory Drawer === */\n#inventoryDrawer {\r\n  position: absolute;\r\n  bottom: 0;\r\n  left: 0; right: 0;\r\n  z-index: 25;\r\n  background: var(--drawer-bg);\r\n  border-top: 1px solid var(--drawer-border);\r\n  border-radius: 20px 20px 0 0;\r\n  transform: translateY(calc(100% - 44px));\r\n  transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);\r\n  max-height: 55vh;\r\n  display: flex;\r\n  flex-direction: column;\r\n  backdrop-filter: blur(20px);\r\n  -webkit-backdrop-filter: blur(20px);\r\n  box-shadow: 0 -8px 40px rgba(0,0,0,0.6);\r\n  padding-bottom: var(--safe-bottom);\r\n}\n#inventoryDrawer.open {\r\n  transform: translateY(0);\r\n}\n.ambient-mode #inventoryDrawer {\r\n  transform: translateY(100%);\r\n}\n#drawerHandle {\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  padding: 8px 16px 4px;\r\n  cursor: pointer;\r\n  touch-action: none;\r\n  transition: opacity 0.2s;\r\n}\n#drawerHandle:active { opacity: 0.6; }\n#handleBar {\r\n  width: 36px; height: 3px;\r\n  background: rgba(255,255,255,0.18);\r\n  border-radius: 2px;\r\n  margin-bottom: 4px;\r\n  transition: background 0.2s;\r\n}\n#inventoryDrawer.open #handleBar {\r\n  background: rgba(255,107,26,0.4);\r\n}\n#drawerTitle {\r\n  font-size: 11px;\r\n  font-weight: 600;\r\n  color: var(--text-dim);\r\n  letter-spacing: 2.5px;\r\n  text-transform: uppercase;\r\n}\n/* === Category Tabs — hidden when empty === */\n#categoryTabs:empty { display: none; }\n#categoryTabs {\r\n  display: flex;\r\n  gap: 6px;\r\n  padding: 0 12px 8px;\r\n  overflow-x: auto;\r\n  scrollbar-width: none;\r\n  -ms-overflow-style: none;\r\n  flex-shrink: 0;\r\n}\n#categoryTabs::-webkit-scrollbar { display: none; }\n.cat-tab {\r\n  flex-shrink: 0;\r\n  padding: 5px 14px;\r\n  border-radius: 14px;\r\n  background: rgba(255,255,255,0.05);\r\n  border: 1px solid rgba(255,255,255,0.08);\r\n  color: var(--text-dim);\r\n  font-size: 12px;\r\n  font-weight: 500;\r\n  cursor: pointer;\r\n  transition: all 0.2s;\r\n  white-space: nowrap;\r\n}\n.cat-tab.active {\r\n  background: rgba(255,107,26,0.2);\r\n  border-color: var(--fire-orange);\r\n  color: var(--fire-orange);\r\n  box-shadow: 0 0 12px rgba(255,107,26,0.2);\r\n}\n/* === Quick Actions Bar (compact toothpick + actions) === */\n#quickActions {\r\n  display: flex;\r\n  gap: 8px;\r\n  padding: 4px 12px 8px;\r\n  flex-shrink: 0;\r\n}\n.quick-btn {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 6px;\r\n  padding: 7px 14px;\r\n  background: rgba(80,45,15,0.6);\r\n  border: 1px solid rgba(255,140,40,0.25);\r\n  border-radius: 12px;\r\n  cursor: pointer;\r\n  transition: all 0.15s;\r\n  font-family: inherit;\r\n  color: var(--text-warm);\r\n}\n.quick-btn:active {\r\n  transform: scale(0.95);\r\n  background: rgba(255,107,26,0.2);\r\n}\n.quick-btn.throw-flash {\r\n  animation: throwFlash 0.25s ease-out;\r\n}\n@keyframes throwFlash {\r\n  0% { border-color: rgba(255,200,80,0.9); box-shadow: 0 0 16px rgba(255,160,40,0.5); }\r\n  100% { border-color: rgba(255,140,40,0.25); }\r\n}\n.qb-icon { font-size: 18px; flex-shrink: 0; }\n.qb-label { font-size: 12px; font-weight: 600; white-space: nowrap; }\n.qb-badge {\r\n  font-size: 10px;\r\n  font-weight: 700;\r\n  color: var(--fire-orange);\r\n  opacity: 0.6;\r\n}\n/* Toothpick: visually prominent but compact */\n#toothpickThrowBtn {\r\n  flex: 1;\r\n  padding: 12px 20px;\r\n  gap: 10px;\r\n  justify-content: flex-start;\r\n  border-color: rgba(255,140,40,0.35);\r\n}\n#toothpickThrowBtn .qb-icon {\r\n  font-size: 26px;\r\n  filter: drop-shadow(0 1px 4px rgba(255,140,40,0.4));\r\n}\n#toothpickThrowBtn .qb-label {\r\n  font-size: 14px;\r\n  font-weight: 700;\r\n  color: var(--fire-white);\r\n}\n#toothpickThrowBtn .qb-badge {\r\n  margin-left: auto;\r\n  font-size: 12px;\r\n  opacity: 0.8;\r\n}\n/* === Cooking Area (floating near fire) === */\n#cookingArea {\r\n  position: absolute;\r\n  left: 12px;\r\n  bottom: calc(58px + var(--safe-bottom));\r\n  z-index: 24;\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  gap: 8px;\r\n  pointer-events: auto;\r\n}\n.ambient-mode #cookingArea { opacity: 0; pointer-events: none; }\n#cookingMenuBtn {\r\n  width: 42px; height: 42px;\r\n  border-radius: 50%;\r\n  background: rgba(0,0,0,0.4);\r\n  border: 1px solid rgba(255,140,40,0.25);\r\n  font-size: 20px;\r\n  cursor: pointer;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  transition: all 0.2s;\r\n  backdrop-filter: blur(8px);\r\n  -webkit-backdrop-filter: blur(8px);\r\n}\n#cookingMenuBtn:active { transform: scale(0.9); }\n#cookingSlots {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 6px;\r\n}\n.cooking-slot {\r\n  position: relative;\r\n  width: 52px; height: 52px;\r\n  border-radius: 14px;\r\n  background: rgba(0,0,0,0.35);\r\n  border: 1px solid rgba(255,140,40,0.2);\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  font-size: 24px;\r\n  cursor: pointer;\r\n  backdrop-filter: blur(6px);\r\n  -webkit-backdrop-filter: blur(6px);\r\n  transition: all 0.2s;\r\n  overflow: hidden;\r\n}\n.cooking-slot:active { transform: scale(0.93); }\n.cooking-slot .cooking-fill {\r\n  position: absolute;\r\n  bottom: 0; left: 0; right: 0;\r\n  height: 0%;\r\n  border-radius: 0 0 13px 13px;\r\n  transition: height 0.3s, background 0.3s;\r\n}\n.cooking-slot[data-state=\"cooking\"] .cooking-fill {\r\n  background: linear-gradient(0deg, rgba(255,160,40,0.35), rgba(255,100,20,0.15));\r\n}\n.cooking-slot[data-state=\"done\"] {\r\n  border-color: rgba(100,255,80,0.5);\r\n  animation: cookDonePulse 1s ease-in-out infinite;\r\n}\n.cooking-slot[data-state=\"done\"] .cooking-fill {\r\n  background: linear-gradient(0deg, rgba(100,255,80,0.3), rgba(80,200,60,0.1));\r\n}\n.cooking-slot[data-state=\"burnt\"] {\r\n  border-color: rgba(100,100,100,0.4);\r\n  opacity: 0.6;\r\n}\n.cooking-slot .cooking-icon {\r\n  position: relative;\r\n  z-index: 1;\r\n  filter: drop-shadow(0 1px 3px rgba(0,0,0,0.5));\r\n}\n.cooking-slot .cooking-label {\r\n  position: absolute;\r\n  bottom: 2px;\r\n  font-size: 8px;\r\n  font-weight: 700;\r\n  color: rgba(255,200,100,0.8);\r\n  z-index: 1;\r\n}\n@keyframes cookDonePulse {\r\n  0%, 100% { box-shadow: 0 0 8px rgba(100,255,80,0.2); }\r\n  50% { box-shadow: 0 0 16px rgba(100,255,80,0.4); }\r\n}\n/* Fire-out state: cooking paused, dim slots with indicator */\n#cookingSlots.fire-out .cooking-slot {\r\n  opacity: 0.4;\r\n  border-color: rgba(100,100,120,0.3);\r\n  animation: none;\r\n}\n#cookingSlots.fire-out .cooking-slot::after {\r\n  content: '❄';\r\n  position: absolute;\r\n  top: 2px;\r\n  right: 3px;\r\n  font-size: 10px;\r\n  z-index: 2;\r\n  opacity: 0.7;\r\n}\n/* === Cooking Menu Popup === */\n#cookingMenu {\r\n  position: absolute;\r\n  left: 12px;\r\n  bottom: calc(110px + var(--safe-bottom));\r\n  z-index: 30;\r\n  background: rgba(15,12,8,0.95);\r\n  border: 1px solid rgba(255,140,40,0.25);\r\n  border-radius: 16px;\r\n  backdrop-filter: blur(16px);\r\n  -webkit-backdrop-filter: blur(16px);\r\n  box-shadow: 0 8px 32px rgba(0,0,0,0.7);\r\n  width: 220px;\r\n  max-height: 300px;\r\n  display: flex;\r\n  flex-direction: column;\r\n  overflow: hidden;\r\n}\n#cookingMenu.hidden { display: none; }\n#cookingMenuHeader {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  padding: 10px 14px;\r\n  border-bottom: 1px solid rgba(255,140,40,0.15);\r\n  font-size: 13px;\r\n  font-weight: 600;\r\n  color: var(--text-warm);\r\n}\n#cookingMenuClose {\r\n  background: none;\r\n  border: none;\r\n  color: var(--text-dim);\r\n  font-size: 18px;\r\n  cursor: pointer;\r\n  padding: 0 2px;\r\n}\n#cookingMenuList {\r\n  overflow-y: auto;\r\n  padding: 6px;\r\n}\n.cooking-menu-item {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 10px;\r\n  padding: 10px 10px;\r\n  border-radius: 10px;\r\n  cursor: pointer;\r\n  transition: background 0.15s;\r\n}\n.cooking-menu-item:active { background: rgba(255,107,26,0.15); }\n.cooking-menu-item .cm-icon { font-size: 22px; flex-shrink: 0; }\n.cooking-menu-item .cm-info { flex: 1; min-width: 0; }\n.cooking-menu-item .cm-name { font-size: 13px; font-weight: 600; color: var(--text-warm); }\n.cooking-menu-item .cm-time {\r\n  font-size: 10px;\r\n  color: var(--text-dim);\r\n  margin-top: 1px;\r\n}\n.cooking-menu-item .cm-reward {\r\n  font-size: 10px;\r\n  color: var(--fire-orange);\r\n  font-weight: 600;\r\n}\n.cooking-menu-item.locked {\r\n  opacity: 0.35;\r\n  pointer-events: none;\r\n}\n.cooking-menu-item.locked .cm-name::after {\r\n  content: ' 🔒';\r\n  font-size: 10px;\r\n}\n/* === Item Grid (for category items when drawer is opened in item mode) === */\n#itemGrid:empty {\r\n  display: none;\r\n}\n#itemGrid {\r\n  display: grid;\r\n  grid-template-columns: repeat(2, 1fr);\r\n  gap: 10px;\r\n  padding: 0 12px 16px;\r\n  overflow-y: auto;\r\n  flex: 1;\r\n  min-height: 0;\r\n  scrollbar-width: thin;\r\n  scrollbar-color: rgba(255,107,26,0.3) transparent;\r\n}\n#itemGrid::-webkit-scrollbar { width: 4px; }\n#itemGrid::-webkit-scrollbar-track { background: transparent; }\n#itemGrid::-webkit-scrollbar-thumb {\r\n  background: rgba(255,107,26,0.3);\r\n  border-radius: 2px;\r\n}\n.item-card {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 12px;\r\n  padding: 12px 14px;\r\n  background: rgba(255,255,255,0.04);\r\n  border: 1px solid rgba(255,255,255,0.07);\r\n  border-radius: 14px;\r\n  cursor: pointer;\r\n  transition: all 0.18s cubic-bezier(0.2,0,0.2,1);\r\n  position: relative;\r\n  overflow: hidden;\r\n}\n.item-card:active, .item-card.burning-flash {\r\n  transform: scale(0.94);\r\n  background: rgba(255,107,26,0.14);\r\n  border-color: rgba(255,107,26,0.4);\r\n}\n.item-card .item-icon {\r\n  width: 44px; height: 44px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  font-size: 26px;\r\n  border-radius: 12px;\r\n  background: rgba(255,255,255,0.06);\r\n  flex-shrink: 0;\r\n}\n.item-card .item-info {\r\n  flex: 1;\r\n  min-width: 0;\r\n}\n.item-card .item-name {\r\n  font-size: 13px;\r\n  font-weight: 600;\r\n  color: var(--text-warm);\r\n  white-space: nowrap;\r\n  overflow: hidden;\r\n  text-overflow: ellipsis;\r\n}\n.item-card .item-desc {\r\n  font-size: 10px;\r\n  color: var(--text-dim);\r\n  margin-top: 2px;\r\n  line-height: 1.3;\r\n  overflow: hidden;\r\n  display: -webkit-box;\r\n  -webkit-line-clamp: 2;\r\n  -webkit-box-orient: vertical;\r\n}\n.item-card .item-rarity-dot {\r\n  position: absolute;\r\n  top: 8px; right: 8px;\r\n  width: 7px; height: 7px;\r\n  border-radius: 50%;\r\n  box-shadow: 0 0 6px currentColor;\r\n}\n.item-card.locked {\r\n  opacity: 0.25;\r\n  filter: grayscale(1);\r\n  pointer-events: none;\r\n}\n.rarity-common .item-icon { border: 1px solid rgba(176,176,176,0.4); }\n.rarity-uncommon .item-icon { border: 1px solid rgba(76,175,80,0.5); }\n.rarity-rare .item-icon { border: 1px solid rgba(33,150,243,0.5); }\n.rarity-epic .item-icon { border: 1px solid rgba(156,39,176,0.5); }\n.rarity-legendary .item-icon { border: 1px solid var(--rarity-legendary); box-shadow: 0 0 10px rgba(255,152,0,0.3); }\n.rarity-mythic .item-icon { border: 1px solid var(--rarity-mythic); box-shadow: 0 0 12px rgba(233,30,99,0.4); animation: mythicGlow 2s ease-in-out infinite; }\n@keyframes mythicGlow {\r\n  0%, 100% { box-shadow: 0 0 8px rgba(233,30,99,0.3); }\r\n  50% { box-shadow: 0 0 20px rgba(233,30,99,0.6), 0 0 40px rgba(233,30,99,0.2); }\r\n}\n/* === Item Modal === */\n#itemModal {\r\n  position: fixed;\r\n  inset: 0;\r\n  z-index: 50;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n}\n#itemModal.hidden { display: none; }\n#modalBackdrop {\r\n  position: absolute;\r\n  inset: 0;\r\n  background: rgba(0,0,0,0.7);\r\n  backdrop-filter: blur(4px);\r\n}\n#modalContent {\r\n  position: relative;\r\n  background: linear-gradient(145deg, rgba(30,20,10,0.98), rgba(15,10,5,0.98));\r\n  border: 1px solid var(--drawer-border);\r\n  border-radius: 20px;\r\n  padding: 28px 24px;\r\n  max-width: 320px;\r\n  width: 85%;\r\n  text-align: center;\r\n  box-shadow: 0 20px 60px rgba(0,0,0,0.8), 0 0 40px rgba(255,107,26,0.1);\r\n}\n#modalIcon {\r\n  width: 72px; height: 72px;\r\n  margin: 0 auto 14px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  font-size: 14px;\r\n  font-weight: 700;\r\n  border-radius: 18px;\r\n  background: rgba(255,255,255,0.05);\r\n  border: 2px solid var(--fire-orange);\r\n}\n#modalName {\r\n  font-size: 20px;\r\n  font-weight: 700;\r\n  margin-bottom: 8px;\r\n  color: var(--fire-white);\r\n}\n#modalDesc {\r\n  font-size: 13px;\r\n  color: var(--text-dim);\r\n  line-height: 1.6;\r\n  margin-bottom: 16px;\r\n}\n#modalStats {\r\n  display: flex;\r\n  justify-content: center;\r\n  gap: 12px;\r\n  margin-bottom: 20px;\r\n}\n#modalStats span {\r\n  padding: 3px 10px;\r\n  border-radius: 10px;\r\n  font-size: 11px;\r\n  font-weight: 500;\r\n}\n#modalRarity {\r\n  background: rgba(255,255,255,0.08);\r\n}\n#modalBurn {\r\n  background: rgba(255,107,26,0.15);\r\n  color: var(--fire-orange);\r\n}\n#burnBtn {\r\n  display: block;\r\n  width: 100%;\r\n  padding: 14px;\r\n  border: none;\r\n  border-radius: 14px;\r\n  background: linear-gradient(135deg, var(--fire-red), var(--fire-orange));\r\n  color: white;\r\n  font-size: 16px;\r\n  font-weight: 700;\r\n  font-family: inherit;\r\n  cursor: pointer;\r\n  transition: all 0.2s;\r\n  box-shadow: 0 4px 20px rgba(255,107,26,0.4);\r\n  margin-bottom: 10px;\r\n  letter-spacing: 1px;\r\n}\n#burnBtn:active {\r\n  transform: scale(0.97);\r\n  box-shadow: 0 2px 10px rgba(255,107,26,0.6);\r\n}\n#modalClose {\r\n  display: block;\r\n  width: 100%;\r\n  padding: 10px;\r\n  border: 1px solid rgba(255,255,255,0.1);\r\n  border-radius: 12px;\r\n  background: transparent;\r\n  color: var(--text-dim);\r\n  font-size: 14px;\r\n  font-family: inherit;\r\n  cursor: pointer;\r\n}\n/* === Combo Display — top-right corner, never covers the fire === */\n#comboDisplay {\r\n  position: absolute;\r\n  top: calc(56px + var(--safe-top));\r\n  right: 14px;\r\n  z-index: 18;\r\n  text-align: right;\r\n  pointer-events: none;\r\n}\n#comboDisplay.hidden { display: none; }\n#comboDisplay.show {\r\n  animation: comboPop 0.35s cubic-bezier(0.2, 0, 0.2, 1.4);\r\n}\n#comboCount {\r\n  display: block;\r\n  font-size: 28px;\r\n  font-weight: 900;\r\n  color: var(--fire-yellow);\r\n  text-shadow: 0 0 14px var(--fire-orange), 0 2px 4px rgba(0,0,0,0.9);\r\n  line-height: 1;\r\n}\n#comboLabel {\r\n  display: block;\r\n  font-size: 10px;\r\n  font-weight: 700;\r\n  letter-spacing: 4px;\r\n  color: var(--fire-orange);\r\n  text-shadow: 0 0 6px var(--fire-orange);\r\n}\n@keyframes comboPop {\r\n  0% { transform: scale(0.4) translateY(-8px); opacity: 0; }\r\n  60% { transform: scale(1.15) translateY(0); }\r\n  100% { transform: scale(1) translateY(0); opacity: 1; }\r\n}\n/* === Achievement Toast === */\n#achievementToast {\r\n  position: absolute;\r\n  top: calc(60px + var(--safe-top));\r\n  left: 50%;\r\n  transform: translateX(-50%) translateY(-20px);\r\n  z-index: 30;\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 10px;\r\n  background: rgba(0,0,0,0.8);\r\n  backdrop-filter: blur(12px);\r\n  border: 1px solid var(--gold);\r\n  border-radius: 16px;\r\n  padding: 10px 20px;\r\n  opacity: 0;\r\n  transition: all 0.4s ease;\r\n  pointer-events: none;\r\n  box-shadow: 0 4px 20px rgba(255,215,0,0.2);\r\n}\n#achievementToast.hidden { display: none; }\n#achievementToast.show {\r\n  display: flex;\r\n  opacity: 1;\r\n  transform: translateX(-50%) translateY(0);\r\n}\n#achievementIcon { font-size: 24px; }\n#achievementText {\r\n  font-size: 13px;\r\n  font-weight: 500;\r\n  color: var(--gold);\r\n}\n/* === Ambient Toggle === */\n#ambientToggle {\r\n  position: absolute;\r\n  top: calc(12px + var(--safe-top));\r\n  left: 50%;\r\n  transform: translateX(-50%);\r\n  z-index: 21;\r\n  background: rgba(0,0,0,0.3);\r\n  border: 1px solid rgba(255,255,255,0.1);\r\n  border-radius: 50%;\r\n  width: 36px; height: 36px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  cursor: pointer;\r\n  color: var(--text-dim);\r\n  transition: all 0.3s;\r\n  opacity: 0.5;\r\n}\n#ambientToggle:hover { opacity: 0.8; }\n.ambient-mode #ambientToggle {\r\n  opacity: 0.3;\r\n  color: var(--fire-orange);\r\n}\n/* === Ambient Mode === */\n.ambient-mode #hud,\r\n.ambient-mode #tempIndicator,\r\n.ambient-mode #ambientToggle {\r\n  opacity: 0;\r\n  pointer-events: none;\r\n}\n/* === Screen Shake Animation === */\n.shaking {\r\n  animation: shake 0.5s ease-in-out;\r\n}\n@keyframes shake {\r\n  0%, 100% { transform: translate(0, 0); }\r\n  10% { transform: translate(-8px, -5px); }\r\n  20% { transform: translate(7px, 6px); }\r\n  30% { transform: translate(-6px, 4px); }\r\n  40% { transform: translate(5px, -7px); }\r\n  50% { transform: translate(-4px, 3px); }\r\n  60% { transform: translate(3px, -2px); }\r\n  70% { transform: translate(-2px, 4px); }\r\n  80% { transform: translate(4px, -1px); }\r\n  90% { transform: translate(-1px, 2px); }\r\n}\n/* === Heavy Shake (explosions) === */\n.heavy-shake {\r\n  animation: heavyShake 0.8s ease-in-out;\r\n}\n@keyframes heavyShake {\r\n  0%, 100% { transform: translate(0,0) rotate(0deg); }\r\n  5% { transform: translate(-15px, -10px) rotate(-1deg); }\r\n  10% { transform: translate(12px, 14px) rotate(1.5deg); }\r\n  15% { transform: translate(-14px, 8px) rotate(-1deg); }\r\n  20% { transform: translate(10px, -12px) rotate(0.5deg); }\r\n  25% { transform: translate(-8px, 6px) rotate(-0.5deg); }\r\n  30% { transform: translate(12px, -5px) rotate(1deg); }\r\n  40% { transform: translate(-6px, 10px) rotate(-0.5deg); }\r\n  50% { transform: translate(8px, -4px) rotate(0.3deg); }\r\n  60% { transform: translate(-4px, 6px) rotate(-0.3deg); }\r\n  70% { transform: translate(5px, -3px) rotate(0.2deg); }\r\n  80% { transform: translate(-2px, 4px); }\r\n  90% { transform: translate(1px, -1px); }\r\n}\n/* === Firework Camera Zoom === */\n.firework-zoom {\r\n  animation: fwZoom 3s ease-in-out;\r\n  transform-origin: 50% 30%;\r\n}\n@keyframes fwZoom {\r\n  0% { transform: scale(1); }\r\n  15% { transform: scale(1.15) translateY(-5%); }\r\n  50% { transform: scale(1.15) translateY(-5%); }\r\n  100% { transform: scale(1); }\r\n}\n/* === Flash Effect === */\n.flash-overlay {\r\n  position: fixed;\r\n  inset: 0;\r\n  z-index: 40;\r\n  pointer-events: none;\r\n  animation: flashAnim 0.6s ease-out forwards;\r\n}\n@keyframes flashAnim {\r\n  0% { background: rgba(255,200,50,0.6); }\r\n  100% { background: transparent; }\r\n}\n.flash-red {\r\n  animation: flashRedAnim 0.5s ease-out forwards;\r\n}\n@keyframes flashRedAnim {\r\n  0% { background: rgba(255,50,20,0.5); }\r\n  100% { background: transparent; }\r\n}\n/* === Responsive === */\n@media (max-width: 380px) {\r\n  #itemGrid { grid-template-columns: 1fr 1fr; gap: 6px; }\r\n  .item-card { padding: 8px 8px; gap: 8px; }\r\n  .item-card .item-icon { width: 32px; height: 32px; font-size: 18px; border-radius: 8px; }\r\n  .item-card .item-name { font-size: 11px; }\r\n  .item-card .item-desc { font-size: 9px; }\r\n  #fireLevelText { font-size: 12px; }\r\n  .currency { font-size: 11px; padding: 4px 8px; }\r\n  .quick-btn { padding: 6px 10px; }\r\n  .qb-icon { font-size: 16px; }\r\n  .qb-label { font-size: 11px; }\r\n  .cat-tab { padding: 4px 10px; font-size: 11px; }\r\n  #cookingMenu { width: 190px; }\r\n}\n@media (min-width: 768px) {\r\n  #itemGrid { grid-template-columns: repeat(3, 1fr); }\r\n  #inventoryDrawer { max-width: 600px; left: 50%; transform: translateX(-50%) translateY(calc(100% - 44px)); }\r\n  #inventoryDrawer.open { transform: translateX(-50%) translateY(0); }\r\n}\n/* === Landscape mode === */\n@media (orientation: landscape) and (max-height: 500px) {\r\n  #inventoryDrawer { max-height: 55vh; }\r\n  #itemGrid { grid-template-columns: repeat(auto-fill, minmax(80px, 1fr)); }\r\n}\n/* === Loading Screen === */\n#loadingScreen {\r\n  position: fixed;\r\n  inset: 0;\r\n  z-index: 100;\r\n  background: var(--night-dark);\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  justify-content: center;\r\n  gap: 20px;\r\n  transition: opacity 0.8s ease;\r\n}\n#loadingScreen.fade-out { opacity: 0; pointer-events: none; }\n.loading-flame {\r\n  width: 60px; height: 80px;\r\n  background: radial-gradient(ellipse at 50% 80%, var(--fire-yellow) 0%, var(--fire-orange) 40%, var(--fire-red) 70%, transparent 100%);\r\n  border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;\r\n  animation: loadFlame 0.8s ease-in-out infinite alternate;\r\n  filter: blur(2px);\r\n}\n@keyframes loadFlame {\r\n  0% { transform: scaleX(0.9) scaleY(1); }\r\n  100% { transform: scaleX(1.1) scaleY(1.1); }\r\n}\n.loading-text {\r\n  font-size: 14px;\r\n  color: var(--text-dim);\r\n  letter-spacing: 4px;\r\n}\n/* === Intro Overlay === */\n#introOverlay {\r\n  position: absolute;\r\n  inset: 0;\r\n  z-index: 200;\r\n  background: #000;\r\n  cursor: pointer;\r\n  touch-action: manipulation;\r\n}\n#introCanvas {\r\n  position: absolute;\r\n  inset: 0;\r\n  width: 100% !important;\r\n  height: 100% !important;\r\n  pointer-events: none;\r\n  z-index: 0;\r\n  filter: none !important;  /* override the global canvas filter */\r\n  mix-blend-mode: normal !important;\r\n}\n#introTapText {\r\n  position: absolute;\r\n  inset: 0;\r\n  z-index: 1;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  font-size: clamp(52px, 13vw, 100px);\r\n  font-weight: 300;\r\n  letter-spacing: 0.4em;\r\n  color: rgba(255, 200, 100, 0);\r\n  text-shadow:\r\n    0 0 40px rgba(255, 140, 40, 0),\r\n    0 0 80px rgba(255, 90, 20, 0);\r\n  transition: color 0.7s ease, text-shadow 0.7s ease;\r\n  pointer-events: none;\r\n  padding-left: 0.4em; /* compensate letter-spacing */\r\n}\n#introTapText.show {\r\n  color: rgba(255, 200, 100, 0.85);\r\n  text-shadow:\r\n    0 0 40px rgba(255, 140, 40, 0.5),\r\n    0 0 80px rgba(255, 90, 20, 0.25);\r\n  animation: introPuls